{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:recommended",
		":label(dependencies)",
		":semanticCommits",
		":semanticCommitTypeAll(build)",
		":disableRateLimiting",
		":automergeMinor",
		":automergeBranch",
		":prNotPending"
	],
	"gitIgnoredAuthors": ["114827586+autofix-ci[bot]@users.noreply.github.com", "29139614+renovate[bot]@users.noreply.github.com"],
	"packageRules": [
		{
			"groupName": "typescript",
			"matchPackageNames": ["typescript", "@tsconfig/**"]
		},
		{
			"matchPackageNames": ["typescript"],
			"matchCurrentVersion": "6",
			"matchNewValue": "/^[^0-9]*7(?:\\.|$)/",
			"automerge": true
		},
		{
			"groupName": "xo",
			"matchPackageNames": ["xo", "eslint-config-xo", "prettier-config-xo", "@jonahsnider/xo-config", "eslint-config-xo-{space,react,typescript,flow}"]
		},
		{
			"groupName": "rollup",
			"matchPackageNames": ["rollup", "@rollup/**", "rollup-plugin-*"]
		},
		{
			"groupName": "drizzle",
			"matchPackageNames": ["drizzle-*"]
		},
		{
			"groupName": "convex",
			"matchPackageNames": ["convex", "convex-*", "@convex-dev/**"]
		},
		{
			"groupName": "error-prone",
			"matchSourceUrls": ["https://github.com/google/error-prone", "https://github.com/PicnicSupermarket/error-prone-support"]
		},
		{
			"groupName": "fallow",
			"matchSourceUrls": ["https://github.com/fallow-rs/fallow"]
		},
		{
			"matchManagers": ["github-actions"],
			"matchPackageNames": ["actions/checkout", "actions/cache", "actions/setup-*"],
			"matchUpdateTypes": ["major"],
			"automerge": true
		},
		{
			"matchDatasources": ["npm"],
			"minimumReleaseAge": "24 hours"
		},
		{
			"matchManagers": ["npm"],
			"matchPackageNames": ["vercel"],
			"matchUpdateTypes": ["major"],
			"automerge": true
		}
	],
	"timezone": "America/Los_Angeles"
}
